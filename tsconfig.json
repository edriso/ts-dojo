{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "*/client/exercise.ts",
    "*/server/exercise.ts",
    "project/shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "project/client",
    "project/server"
  ]
}
